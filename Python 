   "source": [
    "#Я использовала питон для автоматической сборки данных\n",
    "\n",
    "import pandas as pd\n",
    "import os\n",
    "from datetime import datetime\n",
    "\n",
    "downloads_path = os.path.join(os.path.expanduser(\"~\"), \"Downloads\")\n",
    "\n",
    "print(\"=\"*80)\n",
    "print(\"ПОДСЧЕТ ОБЩЕГО КОЛИЧЕСТВА УМЕРШИХ ПО РЕГИОНАМ (СУММИРОВАНИЕ ВСЕХ СТРОК)\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "excel_files = [f for f in os.listdir(downloads_path) if f.endswith(('.xlsx', '.xls'))]\n",
    "\n",
    "print(f\"\\n Найдено {len(excel_files)} Excel файлов в Загрузках:\")\n",
    "\n",
    "for i, file in enumerate(excel_files):\n",
    "    file_size = os.path.getsize(os.path.join(downloads_path, file)) / (1024 * 1024)\n",
    "    print(f\"  {i}. {file} ({file_size:.1f} МБ)\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "choice = input(\"Введите номер файла с данными: \")\n",
    "\n",
    "try:\n",
    "    idx = int(choice)\n",
    "    file_name = excel_files[idx]\n",
    "    file_path = os.path.join(downloads_path, file_name)\n",
    "except:\n",
    "    print(\" Неверный выбор\")\n",
    "    exit()\n",
    "\n",
    "print(f\"\\n Выбран файл: {file_name}\")\n",
    "\n",
    "print(\"\\n Загружаем данные...\")\n",
    "df_raw = pd.read_excel(file_path, header=None)\n",
    "print(f\" Загружено: {df_raw.shape[0]} строк, {df_raw.shape[1]} столбцов\")\n",
    "\n",
    "print(\"\\n Первые 30 строк для анализа:\")\n",
    "print(\"=\"*80)\n",
    "for i in range(min(30, len(df_raw))):\n",
    "    first_cell = str(df_raw.iloc[i, 0])[:50] if pd.notna(df_raw.iloc[i, 0]) else \"\"\n",
    "    second_cell = str(df_raw.iloc[i, 1])[:30] if df_raw.shape[1] > 1 and pd.notna(df_raw.iloc[i, 1]) else \"\"\n",
    "    print(f\"Строка {i:3}: {first_cell:45} | {second_cell}\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\" СБОР ДАННЫХ ПО РЕГИОНАМ\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "region_dict = {}\n",
    "\n",
    "for idx in range(len(df_raw)):\n",
    "    first_cell = str(df_raw.iloc[idx, 0]) if pd.notna(df_raw.iloc[idx, 0]) else \"\"\n",
    "    \n",
    "    is_region = False\n",
    "    region_name = None\n",
    "    \n",
    "    if first_cell and first_cell != 'nan':\n",
    "        if not any(disease in first_cell.lower() for disease in [\n",
    "            'болезни', 'новообразования', 'ишемическая', 'церебро', \n",
    "            'внешние', 'врожденные', 'транспортные', 'самоубийство',\n",
    "            'убийство', 'отравл', 'злокачественные', 'инфекционные',\n",
    "            'отдельные', 'всего', 'итого', 'сумма'\n",
    "        ]):\n",
    "        \n",
    "            if any(region_word in first_cell for region_word in [\n",
    "                'край', 'область', 'республика', 'округ', \n",
    "                'Алтайский', 'Амурская', 'Московская', 'Ленинградская',\n",
    "                'Новосибирская', 'Свердловская', 'Челябинская'\n",
    "            ]):\n",
    "                is_region = True\n",
    "                region_name = first_cell.strip()\n",
    "    \n",
    "    if is_region and region_name:\n",
    "        row_total = 0\n",
    "        years_count = 0\n",
    "        \n",
    "        for col in range(1, df_raw.shape[1]):\n",
    "            value = df_raw.iloc[idx, col]\n",
    "            if pd.notna(value) and value != '' and value is not None:\n",
    "                try:\n",
    "                    if isinstance(value, str):\n",
    "                        value = value.replace(' ', '').replace(' ', '').replace(',', '.')\n",
    "                    num_value = float(value)\n",
    "                    if num_value > 0:\n",
    "                        row_total += num_value\n",
    "                        years_count += 1\n",
    "                except (ValueError, TypeError):\n",
    "                    pass\n",
    "        \n",
    "        if row_total > 0:\n",
    "            if region_name in region_dict:\n",
    "                region_dict[region_name] += row_total\n",
    "                print(f\"  + Добавлено к {region_name}: +{int(row_total):,} = {int(region_dict[region_name]):,}\")\n",
    "            else:\n",
    "                region_dict[region_name] = row_total\n",
    "                print(f\"  + Новый регион: {region_name} - {int(row_total):,} чел.\")\n",
    "\n",
    "print(\"\\n🔍 Ищем итоговые строки 'Всего'...\")\n",
    "\n",
    "for idx in range(len(df_raw)):\n",
    "    first_cell = str(df_raw.iloc[idx, 0]) if pd.notna(df_raw.iloc[idx, 0]) else \"\"\n",
    "    \n",
    "    if first_cell and 'всего' in first_cell.lower():\n",
    "        region_name = first_cell.replace('Всего', '').replace('(', '').replace(')', '').strip()\n",
    "        if region_name and region_name != '' and region_name != 'nan':\n",
    "            \n",
    "            row_total = 0\n",
    "            years_count = 0\n",
    "            \n",
    "            for col in range(1, df_raw.shape[1]):\n",
    "                value = df_raw.iloc[idx, col]\n",
    "                if pd.notna(value) and value != '' and value is not None:\n",
    "                    try:\n",
    "                        if isinstance(value, str):\n",
    "                            value = value.replace(' ', '').replace(' ', '').replace(',', '.')\n",
    "                        num_value = float(value)\n",
    "                        if num_value > 0:\n",
    "                            row_total += num_value\n",
    "                            years_count += 1\n",
    "                    except (ValueError, TypeError):\n",
    "                        pass\n",
    "            \n",
    "            if row_total > 0:\n",
    "                if region_name in region_dict:\n",
    "                    if region_dict[region_name] < row_total:\n",
    "                        region_dict[region_name] = row_total\n",
    "                        print(f\"  Обновлен {region_name} из итоговой строки: {int(row_total):,} чел.\")\n",
    "                else:\n",
    "                    region_dict[region_name] = row_total\n",
    "                    print(f\"  + Итоговая строка: {region_name} - {int(row_total):,} чел.\")\n",
    "\n",
    "region_totals = []\n",
    "for region, total in region_dict.items():\n",
    "    region_totals.append({\n",
    "        'Регион': region,\n",
    "        'Общее количество умерших за все годы': int(total)\n",
    "    })\n",
    "\n",
    "df_results = pd.DataFrame(region_totals)\n",
    "\n",
    "if df_results.empty:\n",
    "    print(\"\\n Не удалось найти данные по регионам!\")\n",
    "    exit()\n",
    "\n",
    "print(\"\\n Объединяем похожие названия регионов...\")\n",
    "\n",
    "df_results['Регион'] = df_results['Регион'].str.strip()\n",
    "\n",
    "df_results = df_results.groupby('Регион', as_index=False)['Общее количество умерших за все годы'].sum()\n",
    "\n",
    "df_results_sorted = df_results.sort_values('Общее количество умерших за все годы', ascending=False).reset_index(drop=True)\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\" РЕЗУЛЬТАТЫ: ОБЩЕЕ КОЛИЧЕСТВО УМЕРШИХ ПО РЕГИОНАМ\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "print(f\"\\n Всего уникальных регионов: {len(df_results_sorted)}\")\n",
    "print(f\" Общая сумма смертей по всем регионам: {df_results_sorted['Общее количество умерших за все годы'].sum():,} чел.\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\" ВСЕ РЕГИОНЫ (от большего к меньшему)\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "for i, (idx, row) in enumerate(df_results_sorted.iterrows(), 1):\n",
    "    print(f\"{i:3}. {row['Регион'][:55]:55} - {row['Общее количество умерших за все годы']:>12,} чел.\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\" ТОП-10 РЕГИОНОВ-ЛИДЕРОВ (самая высокая смертность)\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "top_10 = df_results_sorted.head(10)\n",
    "for i, (idx, row) in enumerate(top_10.iterrows(), 1):\n",
    "    print(f\"{i:2}. {row['Регион'][:55]:55} - {row['Общее количество умерших за все годы']:>12,} чел.\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\" ТОП-10 РЕГИОНОВ-АНТИЛИДЕРОВ (самая низкая смертность)\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "bottom_10 = df_results_sorted.tail(10)\n",
    "for i, (idx, row) in enumerate(bottom_10.iterrows(), 1):\n",
    "    print(f\"{i:2}. {row['Регион'][:55]:55} - {row['Общее количество умерших за все годы']:>12,} чел.\")\n",
    "\n",
    "output_filename = f\"Общая_смертность_по_регионам_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx\"\n",
    "output_path = os.path.join(downloads_path, output_filename)\n",
    "\n",
    "with pd.ExcelWriter(output_path, engine='openpyxl') as writer:\n",
    "    df_results_sorted.to_excel(writer, sheet_name='Все регионы', index=False)\n",
    "    \n",
    "    top_10.to_excel(writer, sheet_name='Топ-10 лидеров', index=False)\n",
    "    \n",
    "    bottom_10.to_excel(writer, sheet_name='Топ-10 антилидеров', index=False)\n",
    "    \n",
    "    stats_data = {\n",
    "        'Показатель': [\n",
    "            'Всего регионов',\n",
    "            'Общая сумма смертей по всем регионам',\n",
    "            'Средняя смертность на регион',\n",
    "            'Максимальная смертность',\n",
    "            'Минимальная смертность',\n",
    "            'Регион с максимальной смертностью',\n",
    "            'Регион с минимальной смертностью'\n",
    "        ],\n",
    "        'Значение': [\n",
    "            len(df_results_sorted),\n",
    "            f\"{df_results_sorted['Общее количество умерших за все годы'].sum():,}\",\n",
    "            f\"{df_results_sorted['Общее количество умерших за все годы'].mean():,.0f}\",\n",
    "            f\"{df_results_sorted['Общее количество умерших за все годы'].max():,}\",\n",
    "            f\"{df_results_sorted['Общее количество умерших за все годы'].min():,}\",\n",
    "            df_results_sorted.iloc[0]['Регион'],\n",
    "            df_results_sorted.iloc[-1]['Регион']\n",
    "        ]\n",
    "    }\n",
    "    stats_df = pd.DataFrame(stats_data)\n",
    "    stats_df.to_excel(writer, sheet_name='Статистика', index=False)\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\" ОТЧЕТ СОХРАНЕН!\")\n",
    "print(\"=\"*80)\n",
    "print(f\" Имя файла: {output_filename}\")\n",
    "print(f\" Путь: {output_path}\")\n",
    "print(\"\\n АНАЛИЗ ЗАВЕРШЕН!\")\n"
   ]
